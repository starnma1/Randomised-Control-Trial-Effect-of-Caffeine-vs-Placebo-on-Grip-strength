  # Evaluate Exclusion criteria
  data$onboarding_eligibility_screening_complete <- factor(data$onboarding_eligibility_screening_complete)
  data <- filter(data, onboarding_eligibility_screening_complete == 2)
  data <- mutate(data, randomization_group = ifelse(randomization_group == "MASKED_GROUP_A", "Treatment", "Placebo"))
    
  data <- data %>%
    
      # Remove NAs, start analysis if they tok initial specs
      filter(initial_physiology_hrbp_complete == 2
           )%>%
      
      # Biological sex
      mutate(biological_sex = factor(biological_sex, levels = c(0,1,2,3), labels = c("Female", "Male", "Other", "PreferNotToSay"))
             ) %>%
      
      # Dominant Hand label
      mutate(dominant_hand = factor(dominant_hand, levels = c(1,2,3), labels = c("Right", "Left", "Ambidextrous"))
             ) %>%
    
      # Daily caffeine intake
      mutate(daily_caffeine_intake = factor(daily_caffeine_intake, 
                                            levels = 0:6, 
                                            labels = c("0 mg/day", "1-50 mg/day", "51-100 mg/day",
                                                                     "101-200 mg/day", "201-400 mg/day", ">400 mg/day","PreferNotToSay"))
             ) %>%
      # Resistance traning
      mutate(pretrial_survey_exercise = factor(pretrial_survey_exercise,
                                                  levels = 0:6,
                                                  labels = c("Never", "<1x/week", "1x/week",
                                                             "2x/week", "3x/week", ">=4x/week", "PreferNotToSay"))
      ) %>%
      # Assumed treatment
      mutate(offboarding_group_assoc = factor(offboarding_group_assoc,
                                              levels = c(0,1,2),
                                              labels = c("Treatment", "Placebo", "IDK"))
             ) %>%
      # Percieved Strength
      mutate(offboarding_strength = factor(offboarding_strength))

  
