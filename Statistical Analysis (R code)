## Primary Analysis ----
##########################################################################################################################################.
    
    # Primary analysis evaluates whether the inntervention affected the maximal grip strength,
    # taking into account the pre-measurement, weight and study_id as random intercept. Nonetheless,
    # all models will be made and evaluated comparativly.
    
    ### Pivot data for models ----
    pivoted_analysis <- pivot_longer(exploratory_data, cols = c("final_grip_strength_m1", "final_grip_strength_m2", "final_grip_strength_m3"),
                                     names_to = "Trial", values_to = "Grip_Strength")
    
    ### Research Question model ----
    RQ_model1 <- glmmTMB(Grip_Strength ~ randomization_group + initial_physiology_weight + initial_grip_strength_mean + (1|study_id), data = pivoted_analysis)
    RQ_model2 <- glmmTMB(Grip_Strength ~ randomization_group + initial_grip_strength_mean + (1|study_id), data = pivoted_analysis)
    anova(RQ_model1, RQ_model2)
    
    primary_model <- RQ_model1
    
      # It does not seem that weight was as large of a con-founder as we thought, nonetheless, 
      # the primary analysis was defined in the SAP and we must thus stick with it.
    
    ### Internal model validation ----
    source("/Users/matistarnawski/Desktop/University of Zurich/SEMESTER 7/Applied Statistics/Recap Scripts 2/Custom functions.r")
    
